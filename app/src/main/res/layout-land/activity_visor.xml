<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/visor_root"
    android:keepScreenOn="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="false">

    <FrameLayout
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <FrameLayout
        android:id="@+id/camera_preview_touch_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top row: buttons left, exit right -->
    <Button
        android:id="@+id/button_exit"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="✕"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:background="@drawable/button_exit_round_corners"
        android:contentDescription="@string/button_exit_description"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:layout_margin="4dp"
        android:elevation="8dp"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp" />

    <LinearLayout
        android:id="@+id/button_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <Button android:id="@+id/button_flash"
            android:layout_width="36dp" android:layout_height="36dp"
            android:text="🔦" android:textSize="18sp"
            android:background="@drawable/button_flash_round_corners"
            android:contentDescription="@string/button_flash_description"
            android:elevation="8dp"
            android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" />

        <Button android:id="@+id/button_color"
            android:layout_width="36dp" android:layout_height="36dp"
            android:layout_marginLeft="18dp"
            android:text="◐" android:textSize="18sp" android:textColor="#FFFFFF"
            android:background="@drawable/button_color_round_corners"
            android:contentDescription="@string/button_color_description"
            android:elevation="8dp"
            android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" />

        <Button android:id="@+id/settings_button"
            android:layout_width="36dp" android:layout_height="36dp"
            android:layout_marginLeft="18dp"
            android:text="⚙" android:textSize="18sp" android:textColor="#FFFFFF"
            android:background="@drawable/button_settings_round_corners"
            android:elevation="8dp"
            android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" />
    </LinearLayout>

    <!-- Zoom group: right side, centered vertically, under exit -->
    <LinearLayout
        android:id="@+id/zoom_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginRight="4dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:elevation="8dp">

        <Button android:id="@+id/button_zoom_in"
            android:layout_width="36dp" android:layout_height="36dp"
            android:text="🔍+" android:textSize="12sp" android:textColor="#000000"
            android:background="@drawable/button_zoom_round_corners"
            android:contentDescription="@string/button_zoom_in_description"
            android:elevation="8dp"
            android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" />

        <TextView android:id="@+id/zoom_label"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="1.0x"
            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
            android:shadowColor="#000000" android:shadowDx="1" android:shadowDy="1" android:shadowRadius="3"
            android:paddingTop="2dp" android:paddingBottom="2dp" />

        <Button android:id="@+id/button_zoom_out"
            android:layout_width="36dp" android:layout_height="36dp"
            android:text="🔍−" android:textSize="12sp" android:textColor="#000000"
            android:background="@drawable/button_zoom_round_corners"
            android:contentDescription="@string/button_zoom_out_description"
            android:elevation="8dp"
            android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" />
    </LinearLayout>

    <Button android:id="@+id/button_photo"
        android:visibility="invisible"
        android:layout_width="0dp" android:layout_height="0dp" />

    <Button android:id="@+id/button_pause"
        android:layout_width="36dp" android:layout_height="36dp"
        android:text="⏸" android:textSize="18sp" android:textColor="#000000"
        android:background="@drawable/button_zoom_round_corners"
        android:contentDescription="@string/button_pause_description"
        android:layout_alignParentBottom="true"
        android:layout_alignParentRight="true"
        android:layout_margin="4dp"
        android:elevation="8dp"
        android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" />

</RelativeLayout>
